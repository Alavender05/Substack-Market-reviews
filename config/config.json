{
  "profile": {
    "substack_profile_url": "https://substack.com/@aleclavender",
    "reads_enabled": true
  },
  "pipeline": {
    "article_fetch_limit_per_run": 10,
    "save_raw_html": true,
    "daily_run_timezone": "UTC"
  },
  "summarization": {
    "enabled": true,
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "summary_length": "medium",
    "max_input_chars": 12000,
    "include_bullets": true
  },
  "output": {
    "latest_dir": "output/latest",
    "archive_dir": "output/archive",
    "articles_file": "articles_enriched.json",
    "digest_file": "daily_digest.json",
    "dashboard_file": "dashboard_feed.json"
  },
  "logging": {
    "level": "INFO",
    "log_to_file": true,
    "log_dir": "logs",
    "json_logs": false
  },
  "deduplication": {
    "enabled": true,
    "dedupe_key": "canonical_url",
    "fallback_to_content_hash": true,
    "seen_articles_path": "data/state/seen_articles.json",
    "skip_existing_articles": true
  },
  "fetching": {
    "request_timeout_seconds": 20,
    "browser_wait_until": "networkidle",
    "max_retries": 2,
    "user_agent": "SubstackReadsCollector/0.1"
  },
  "preflight": {
    "dns_hosts": [
      "github.com",
      "substack.com",
      "newsletter.doomberg.com",
      "www.hfir.com"
    ],
    "http_urls": [
      "https://github.com",
      "https://substack.com"
    ],
    "headers": {
      "User-Agent": "Mozilla/5.0"
    }
  },
  "monitoring": {
    "discovery_mode": "registry_only",
    "rss_enabled": true,
    "html_fallback_enabled": true,
    "publication_expiry_days": 30,
    "max_posts_per_publication_per_run": 5,
    "max_publications_per_run": 20,
    "publications_registry_path": "data/state/publications_registry.json",
    "publication_seeds_path": "config/publication_seeds.json"
  }
}
